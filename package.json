{
  "name": "github-activity-digest",
  "version": "1.0.0",
  "description": "Self-hosted weekly GitHub activity digest generator.",
  "main": "dist/cli.js",
  "scripts": {
    "dev": "tsx watch src/cli.ts serve",
    "build": "tsc && tailwindcss -i ./src/styles.css -o ./public/styles.css --minify",
    "serve": "node dist/cli.js serve",
    "generate": "npm run build && node dist/cli.js generate",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "Benjamin Lannon",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.9.0",
    "node-cron": "^4.5.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "@types/node": "^25.9.4",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
